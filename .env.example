# ================================
# BANCO DE DADOS
# ================================
DATABASE_URL="postgresql://usuario:senha@localhost:5432/minhaclinica"

# ================================
# SERVIDOR
# ================================
PORT=3001
NODE_ENV=development         # development | production

# ================================
# AUTENTICAÇÃO JWT
# ================================
JWT_ACCESS_SECRET=sua_chave_secreta_muito_longa_e_aleatoria
JWT_TEMP_SECRET=outra_chave_secreta_para_tokens_temporarios

# ================================
# URLs
# ================================
FRONTEND_URL=http://localhost:5173   # URL do frontend (usada nos links dos emails)
APP_URL=http://localhost:3001        # URL pública do backend (usada para gerar links de uploads)

# ================================
# EMAIL — Gmail SMTP (desenvolvimento)
# ================================
# Guia: myaccount.google.com/security → Senhas de app
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ================================
# EMAIL — Brevo (produção)
# ================================
# 1. Crie conta em brevo.com
# 2. Vá em "SMTP & API" → "API Keys" → crie uma chave
# 3. Em "Senders" → adicione e verifique o remetente
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Minha Clínica <noreply@seudominio.com.br>
