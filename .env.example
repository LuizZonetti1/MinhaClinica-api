# ================================
# BANCO DE DADOS
# ================================
DATABASE_URL="postgresql://usuario:senha@localhost:5432/minhaclinica"

# ================================
# SERVIDOR
# ================================
PORT=3001
NODE_ENV=development         # development | production

# ================================
# AUTENTICAÇÃO JWT
# ================================
JWT_SECRET=sua_chave_secreta_muito_longa_e_aleatoria
JWT_TEMP_SECRET=outra_chave_secreta_para_tokens_temporarios

# ================================
# URLs
# ================================
FRONTEND_URL=http://localhost:5173   # URL do frontend (usada nos links dos emails)

# ================================
# EMAIL — Resend (https://resend.com)
# ================================
# 1. Crie uma conta gratuita em resend.com
# 2. Vá em "API Keys" → "Create API Key"
# 3. Cole a chave abaixo
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Remetente do email
# - Para testes sem domínio próprio: use "onboarding@resend.dev" (só envia para seu email cadastrado no Resend)
# - Com domínio verificado: use um email do seu domínio
EMAIL_FROM=Minha Clínica <noreply@seudominio.com.br>

# Defina como "true" para forçar envio real mesmo em desenvolvimento
# Útil para testar o Resend localmente antes de ir para produção
FORCE_REAL_EMAIL=false
